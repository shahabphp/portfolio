# pakshekar.ir — static Next.js export on Apache / DirectAdmin
# This file is copied into ./out on every `npm run build`.

Options -Indexes
AddDefaultCharset utf-8

# The generated Open Graph image has no file extension — force its MIME type
# so social scrapers (X, Facebook, LinkedIn, Telegram) accept it.
<Files "opengraph-image">
  ForceType image/png
</Files>

# Force HTTPS. Comment this block out if TLS is terminated by a proxy/CDN.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{HTTPS} !=on
  RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
</IfModule>

# Serve the static 404 page.
ErrorDocument 404 /404.html

# Gzip compression.
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css text/plain text/xml \
    application/javascript application/json image/svg+xml
</IfModule>

# Caching + basic security headers.
<IfModule mod_headers.c>
  # Hashed build assets never change — cache them for a year.
  <FilesMatch "\.(js|mjs|css|woff2)$">
    Header set Cache-Control "public, max-age=31536000, immutable"
  </FilesMatch>
  # HTML must always revalidate so deploys go live immediately.
  <FilesMatch "\.html$">
    Header set Cache-Control "public, max-age=0, must-revalidate"
  </FilesMatch>
  Header set X-Content-Type-Options "nosniff"
  Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>
